<Window x:Class="WSChat.Client.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WSChat - Login / Register"
        Height="450" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="Black">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WSChat"
                   FontSize="28" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1"
                   x:Name="ModeText"
                   Text="Login"
                   FontSize="18"
                   Foreground="LightBlue"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Username:" Foreground="White" FontWeight="Bold"/>
            <TextBox x:Name="LoginBox"
                     Height="35"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="Gray"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Password:" Foreground="White" FontWeight="Bold"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="35"
                         Background="#333"
                         Foreground="White"
                         BorderBrush="Gray"
                         Padding="8"/>
        </StackPanel>
        <StackPanel Grid.Row="4"
                    x:Name="EmailPanel"
                    Margin="0,0,0,10"
                    Visibility="Collapsed">
                    <TextBlock Text="Email:" Foreground="White" FontWeight="Bold"/>
            <TextBox x:Name="EmailBox"
                     Height="35"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="Gray"
                     Padding="8"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
            <Button Content="Register"
                    Width="140" Height="40"
                    Margin="0,0,15,0"
                    Background="#8E44AD" Foreground="White" FontWeight="Bold"
                    Click="ToggleRegister_Click"/>
            <Button x:Name="LoginButton" 
                    Content="Login"
                    Width="140" Height="40"
                    Background="#0066CC" Foreground="White" FontWeight="Bold"
                    Click="Login_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="6" HorizontalAlignment="Center">
            <CheckBox x:Name="RememberMeCheckBox"
                      Content="Remember me"
                      Foreground="LightGray"
                      Margin="0,0,0,10"/>
            <TextBlock x:Name="StatusText"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>